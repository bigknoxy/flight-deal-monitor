# Flight Deal Monitor Configuration

# fli (Primary - FREE Google Flights via curl_cffi)
# No API key required - uses curl_cffi to access Google Flights directly

# SearchAPI (Fallback - Recommended for reliable results)
# https://www.searchapi.io/docs/google-flights-api
SEARCHAPI_API_KEY=your_searchapi_key_here

# Duffel API (Backup - Air Booking API)
DUFFEL_API_TOKEN=your_duffel_token_here

# Telegram Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack (optional)
SLACK_WEBHOOK_URL=

# Discord (optional)
DISCORD_WEBHOOK_URL=

# Email (optional - SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# Database (SQLite default, PostgreSQL for production)
DATABASE_URL=sqlite:///./flight_deals.db

# Optional: Logging
LOG_LEVEL=INFO