# Flight Deal Monitor Configuration

# SearchAPI (Google Flights) - https://www.searchapi.com/
SEARCHAPI_API_KEY=your_searchapi_key_here

# PostgreSQL (for storing deals)
DATABASE_URL=postgresql://user:pass@localhost/flight_deals

# Optional: Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Environment
ENV=development
